{
  "Id": "key-policy",
  "Version": "2010-10-17",
  "Statement": [
    {
      "Sid": "Deny",
      "Effect": "Deny",
      "Resource": "*",
      "Condition": {
        "ArnNotLike": {
          "aws:PrincipalArn": "arn:aws:iam::ACCOUNT_ID:role/ROLE_NAME"
        }
      },
      "Action": [
        "kms:*"
      ]
    },
    {
      "Sid": "Enable IAM User Permissions",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::ACCOUNT_ID:root"
      },
      "Action": "kms:*",
      "Resource": "*"
    }
  ]
}